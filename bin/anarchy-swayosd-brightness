#!/bin/bash

# anarchy:summary=Display brightness level using SwayOSD on the current monitor.
# anarchy:args=<0-100>
# anarchy:examples=anarchy swayosd brightness 0 | anarchy swayosd brightness 50 | anarchy swayosd brightness 100

percent="$1"

progress="$(awk -v p="$percent" 'BEGIN{printf "%.2f", p/100}')"
[[ $progress == "0.00" ]] && progress="0.01"

anarchy-swayosd-client \
  --custom-icon display-brightness-symbolic \
  --custom-progress "$progress" \
  --custom-progress-text "$(printf '%3d%%' "$percent")"
