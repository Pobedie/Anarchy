#!/bin/bash

# anarchy:summary=Set the ANARCHY channel, which dictates what git branch and package repository is used.
# anarchy:args=<stable|rc|edge|dev>
# anarchy:requires-sudo=true

if (($# == 0)); then
  echo "Usage: anarchy-channel-set [stable|rc|edge|dev]"
  exit 1
else
  channel="$1"
fi

case "$channel" in
"stable") anarchy-branch-set "master" && anarchy-refresh-pacman "stable" ;;
"rc") anarchy-branch-set "rc" && anarchy-refresh-pacman "rc" ;;
"edge") anarchy-branch-set "master" && anarchy-refresh-pacman "edge" ;;
"dev") anarchy-branch-set "dev" && anarchy-refresh-pacman "edge" ;;
*) echo "Unknown channel: $channel"; exit 1; ;;
esac

anarchy-update -y
