#!/bin/bash

# anarchy:summary=Set or toggle rounded Walker corners
# anarchy:args=[toggle|sharp|round]
# anarchy:examples=anarchy style corners walker toggle | anarchy style corners walker round | anarchy style corners walker sharp

TOGGLES_CSS="$HOME/.local/state/anarchy/toggles/walker.css"

set_radius() {
  local radius="$1"

  mkdir -p "$(dirname "$TOGGLES_CSS")"
  touch "$TOGGLES_CSS"

  if grep -q '^  border-radius:' "$TOGGLES_CSS"; then
    sed -i "s/^  border-radius:.*/  border-radius: ${radius}px;/" "$TOGGLES_CSS"
  elif grep -q '^border-radius:' "$TOGGLES_CSS"; then
    sed -i "s/^border-radius:.*/border-radius: ${radius}px;/" "$TOGGLES_CSS"
  else
    echo ".box-wrapper { border-radius: ${radius}px; }" >>"$TOGGLES_CSS"
  fi
}

case "${1:-toggle}" in
  round) set_radius 6 ;;
  sharp) set_radius 0 ;;
  toggle)
    if [[ -f $TOGGLES_CSS ]] && grep -q 'border-radius: 6px;' "$TOGGLES_CSS"; then
      set_radius 0
    else
      set_radius 6
    fi
    ;;
  *)
    echo "Usage: anarchy-style-corners-walker [toggle|sharp|round]"
    exit 1
    ;;
esac

anarchy-restart-walker
