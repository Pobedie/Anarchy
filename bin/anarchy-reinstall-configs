#!/bin/bash

# anarchy:summary=Reset all ANARCHY user configs to the defaults
# anarchy:requires-sudo=true

set -e

# Overwrite all user configs with the ANARCHY defaults.

if (( EUID == 0 )); then
  echo "Error: This script should not be run as root"
  exit 1
fi

echo "Resetting all ANARCHY configs"
cp -R ~/.local/share/anarchy/config/* ~/.config/
cp ~/.local/share/anarchy/default/bashrc ~/.bashrc
echo '[[ -f ~/.bashrc ]] && . ~/.bashrc' | tee ~/.bash_profile >/dev/null

$(bash $ANARCHY_PATH/install/config/theme.sh)

anarchy-refresh-limine
anarchy-refresh-plymouth
anarchy-nvim-setup
