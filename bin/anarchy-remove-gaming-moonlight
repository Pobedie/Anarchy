#!/bin/bash

# anarchy:summary=Remove Moonlight and its configs and caches.
# anarchy:requires-sudo=true

set -e

anarchy-pkg-drop moonlight-qt

rm -rf \
  "$HOME/.config/Moonlight Game Streaming Project" \
  "$HOME/.cache/Moonlight Game Streaming Project"

echo ""
echo "Moonlight and its data have been removed."
