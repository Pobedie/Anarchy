#!/bin/bash

# omarchy:summary=Reset all ANARCHY user configs to the defaults
# omarchy:requires-sudo=true

set -e

# Overwrite all user configs with the ANARCHY defaults.

if (( EUID == 0 )); then
  echo "Error: This script should not be run as root"
  exit 1
fi

echo "Resetting all ANARCHY configs"
cp -R ~/.local/share/omarchy/config/* ~/.config/
cp ~/.local/share/omarchy/default/bashrc ~/.bashrc
echo '[[ -f ~/.bashrc ]] && . ~/.bashrc' | tee ~/.bash_profile >/dev/null

$(bash $OMARCHY_PATH/install/config/theme.sh)

omarchy-refresh-limine
omarchy-refresh-plymouth
omarchy-nvim-setup
