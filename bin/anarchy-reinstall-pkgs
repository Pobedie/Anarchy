#!/bin/bash

# anarchy:summary=Reinstall all default ANARCHY packages from the stable channel
# anarchy:requires-sudo=true

set -e

# Reinstall all default ANARCHY packages from the stable channel and downgrade any packages that are too new.

# Set the package repository to the stable mirrors
anarchy-refresh-pacman

# Downgrade any packages to the stable setup
sudo pacman -Suu --noconfirm

# Ensure all packages are installed
mapfile -t packages < <(grep -v '^#' "$ANARCHY_PATH/install/anarchy-base.packages" | grep -v '^$')
sudo pacman -Syu --noconfirm --needed "${packages[@]}"
