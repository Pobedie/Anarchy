#!/bin/bash

# omarchy:summary=Launch a floating terminal with the ANARCHY presentation wrapper
# omarchy:args=<command>

cmd="$*"
exec setsid uwsm-app -- xdg-terminal-exec --app-id=org.omarchy.terminal --title=ANARCHY -e bash -c "omarchy-show-logo; $cmd; if (( \$? != 130 )); then omarchy-show-done; fi"
