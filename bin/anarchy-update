#!/bin/bash

# anarchy:summary=Update ANARCHY and system packages
# anarchy:args=[-y]
# anarchy:examples=anarchy update | anarchy update -y
# anarchy:requires-sudo=true

set -e

# Run the update inside a PTY so pacman/yay keep showing download progress
# while still logging the full session for later analysis.
if [[ -z $ANARCHY_UPDATE_LOGGED ]]; then
  script_command=$(printf '%q ' "$0" "$@")
  exec env ANARCHY_UPDATE_LOGGED=1 script -qefc "$script_command" "/tmp/anarchy-update.log"
fi

trap 'echo ""; echo -e "\033[0;31mSomething went wrong during the update!\n\nPlease review the output above carefully, correct the error, and retry the update.\n\nIf you need assistance, get help from the community at https://anarchy.org/discord\033[0m"' ERR

if [[ $1 == "-y" ]] || anarchy-update-confirm; then
  anarchy-snapshot create || (($? == 127))
  anarchy-update-git
  anarchy-update-perform
fi
