#!/bin/bash

# omarchy:summary=Finish the installation of ANARCHY with items that can only be done after logging in.
# omarchy:requires-sudo=true

set -e

FIRST_RUN_MODE=~/.local/state/omarchy/first-run.mode

if [[ -f $FIRST_RUN_MODE ]]; then
  rm -f "$FIRST_RUN_MODE"

  bash "$ANARCHY_PATH/install/first-run/battery-monitor.sh"
  bash "$ANARCHY_PATH/install/first-run/recover-internal-monitor.sh"
  bash "$ANARCHY_PATH/install/first-run/cleanup-reboot-sudoers.sh"
  bash "$ANARCHY_PATH/install/first-run/firewall.sh"
  bash "$ANARCHY_PATH/install/first-run/dns-resolver.sh"
  bash "$ANARCHY_PATH/install/first-run/gnome-theme.sh"
  bash "$ANARCHY_PATH/install/first-run/gdk-scale.sh"
  bash "$ANARCHY_PATH/install/first-run/swayosd.sh"
  bash "$ANARCHY_PATH/install/first-run/gtk-primary-paste.sh"
  bash "$ANARCHY_PATH/install/first-run/elephant.sh"
  sudo rm -f /etc/sudoers.d/first-run

  bash "$ANARCHY_PATH/install/first-run/welcome.sh"
  bash "$ANARCHY_PATH/install/first-run/wifi.sh"
fi
