#!/bin/bash

# omarchy:summary=Reinstall the stable ANARCHY source directory from git

set -e

# Reinstall the ANARCHY configuration directory from the git source.

git clone --depth=1 --branch master "https://github.com/basecamp/omarchy.git" ~/.local/share/omarchy-new >/dev/null
mv $ANARCHY_PATH ~/.local/share/omarchy-old
mv ~/.local/share/omarchy-new $ANARCHY_PATH
