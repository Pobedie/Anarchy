#!/bin/bash

# anarchy:summary=Run the full ANARCHY update pipeline
# anarchy:requires-sudo=true

set -e

# Ensure screensaver/sleep doesn't set in during updates
hyprctl dispatch 'hl.dsp.window.tag({ tag = "+noidle" })' &>/dev/null || hyprctl dispatch tagwindow +noidle &>/dev/null || true

# Perform all update steps
anarchy-update-keyring
anarchy-update-available-reset
anarchy-update-system-pkgs
anarchy-migrate
anarchy-update-aur-pkgs
anarchy-update-orphan-pkgs
anarchy-hook post-update

anarchy-update-analyze-logs

anarchy-update-restart

# Re-enable screensaver/sleep after updates
hyprctl dispatch 'hl.dsp.window.tag({ tag = "-noidle" })' &>/dev/null || hyprctl dispatch tagwindow -- -noidle &>/dev/null || true
