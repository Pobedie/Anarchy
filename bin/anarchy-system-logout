#!/bin/bash

# anarchy:summary=Log out after closing application windows
# anarchy:examples=anarchy logout | anarchy system logout
# anarchy:aliases=anarchy logout

nohup bash -c "sleep 2 && uwsm stop" >/dev/null 2>&1 &

# Now close all windows
anarchy-hyprland-window-close-all
sleep 1 # Allow apps like Chrome to shutdown correctly
