#!/bin/bash

# anarchy:summary=Restore the default ANARCHY Plymouth boot theme and SDDM login screen
# anarchy:requires-sudo=true

theme_dir="/usr/share/plymouth/themes/anarchy"

sudo find ~/.local/share/anarchy/default/plymouth -maxdepth 1 -type f -exec cp -t "$theme_dir/" {} +
sudo plymouth-set-default-theme anarchy

if anarchy-cmd-present limine-mkinitcpio; then
  sudo limine-mkinitcpio
else
  sudo mkinitcpio -P
fi

anarchy-refresh-sddm
