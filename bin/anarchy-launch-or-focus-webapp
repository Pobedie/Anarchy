#!/bin/bash

# anarchy:summary=Launch or focus on a given web app identified by the window-pattern.
# anarchy:args=<window-pattern> <url-and-flags...>

if (($# == 0)); then
  echo "Usage: anarchy-launch-or-focus-webapp [window-pattern] [url-and-flags...]"
  exit 1
fi

WINDOW_PATTERN="$1"
shift
LAUNCH_COMMAND="anarchy-launch-webapp $@"

exec anarchy-launch-or-focus "$WINDOW_PATTERN" "$LAUNCH_COMMAND"
