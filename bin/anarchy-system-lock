#!/bin/bash

# anarchy:summary=Lock the computer and turn off the display
# anarchy:group=system
# anarchy:name=lock
# anarchy:examples=anarchy system lock

if ! pidof hyprlock >/dev/null; then
  (
    hyprlock
    anarchy-system-wake
  ) &
fi

# Set keyboard layout to default (first layout)
hyprctl switchxkblayout all 0 > /dev/null 2>&1

# Ensure 1password is locked
if pgrep -x "1password" >/dev/null; then
  1password --lock &
fi

# Avoid running screensaver when locked
pkill -f org.anarchy.screensaver

if [[ ${ANARCHY_LOCK_ONLY:-false} != "true" ]]; then
  (
    sleep 3
    pidof hyprlock >/dev/null || exit 0
    anarchy-brightness-keyboard off
    anarchy-brightness-display off
  ) &
fi
