#!/bin/bash

# anarchy:summary=Reinstall ANARCHY packages and reset default configs
# anarchy:requires-sudo=true

set -e

# Attempt to reinstall all default ANARCHY packages and reset all the default configs.

echo -e "This will reinstall all the default ANARCHY packages and reset all default configs.\nWarning: All user changes to configs will be lost.\n"

if gum confirm "Are you sure you want to reinstall and lose all config changes?"; then
  anarchy-reinstall-git
  anarchy-reinstall-pkgs
  anarchy-reinstall-configs

  gum confirm "System has been reinstalled. Reboot?" && anarchy-system-reboot
fi
