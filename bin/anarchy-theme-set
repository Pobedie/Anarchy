#!/bin/bash

# anarchy:summary=Apply an ANARCHY theme
# anarchy:args=<theme-name>
# anarchy:examples=anarchy theme list | anarchy theme set "Tokyo Night"

if [[ -z $1 ]]; then
  echo "Usage: anarchy-theme-set <theme-name>"
  exit 1
fi

CURRENT_THEME_PATH="$HOME/.config/anarchy/current/theme"
NEXT_THEME_PATH="$HOME/.config/anarchy/current/next-theme"
USER_THEMES_PATH="$HOME/.config/anarchy/themes"
ANARCHY_THEMES_PATH="$ANARCHY_PATH/themes"

THEME_NAME=$(echo "$1" | sed -E 's/<[^>]+>//g' | tr '[:upper:]' '[:lower:]' | tr ' ' '-')

if [[ ! -d $ANARCHY_THEMES_PATH/$THEME_NAME ]] && [[ ! -d $USER_THEMES_PATH/$THEME_NAME ]]; then
  echo "Theme '$THEME_NAME' does not exist"
  exit 1
fi

# Setup clean next theme directory (for atomic theme config swapping)
rm -rf "$NEXT_THEME_PATH"
mkdir -p "$NEXT_THEME_PATH"

# Copy official theme first, then overlay user customizations on top
cp -r "$ANARCHY_THEMES_PATH/$THEME_NAME/"* "$NEXT_THEME_PATH/" 2>/dev/null
cp -r "$USER_THEMES_PATH/$THEME_NAME/"* "$NEXT_THEME_PATH/" 2>/dev/null

# Generate colors.toml from alacritty.toml if theme is missing colors.toml
if [[ ! -f $NEXT_THEME_PATH/colors.toml && -f $NEXT_THEME_PATH/alacritty.toml ]]; then
  anarchy-theme-colors-from-alacritty "$NEXT_THEME_PATH"
fi

# Generate dynamic configs
anarchy-theme-set-templates

# Swap next theme in as current
rm -rf "$CURRENT_THEME_PATH"
mv "$NEXT_THEME_PATH" "$CURRENT_THEME_PATH"

# Store theme name for reference
echo "$THEME_NAME" >"$HOME/.config/anarchy/current/theme.name"

# Change background with theme
if [[ $ANARCHY_THEME_SKIP_BACKGROUND != "1" ]]; then
  anarchy-theme-bg-next
fi

# Restart components to apply new theme
if pgrep -x waybar >/dev/null; then
  anarchy-restart-waybar
fi
anarchy-restart-swayosd
anarchy-restart-terminal
anarchy-restart-hyprctl
anarchy-restart-btop
anarchy-restart-opencode
anarchy-restart-mako
anarchy-restart-helix

# Change app-specific themes
anarchy-theme-set-foot
anarchy-theme-set-gnome
anarchy-theme-set-browser
anarchy-theme-set-vscode
anarchy-theme-set-obsidian
anarchy-theme-set-keyboard

# Call hook on theme set
anarchy-hook theme-set "$THEME_NAME" >/dev/null

# Warm the background selector cache after the theme is applied, off the critical path.
anarchy-theme-bg-cache >/dev/null 2>&1 &
