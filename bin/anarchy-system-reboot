#!/bin/bash

# anarchy:summary=Reboot after closing application windows
# anarchy:examples=anarchy reboot | anarchy system reboot
# anarchy:aliases=anarchy reboot

anarchy-state clear re*-required

# Schedule the reboot to happen after closing windows (detached from terminal)
nohup bash -c "sleep 2 && systemctl reboot --no-wall" >/dev/null 2>&1 &

# Now close all windows
anarchy-hyprland-window-close-all
sleep 1 # Allow apps like Chrome to shutdown correctly
