#!/bin/bash

# anarchy:summary=Set the Plymouth boot theme from an ANARCHY theme
# anarchy:args=<theme-name>
# anarchy:requires-sudo=true

# Resolve a theme by name and apply its unlock.png + colors.toml as the
# Plymouth boot screen via anarchy-plymouth-set.

if [[ $# -ne 1 ]]; then
  echo "Usage: anarchy-plymouth-set-by-theme <theme-name>" >&2
  exit 1
fi

theme=$1

if [[ -d ~/.config/anarchy/themes/$theme ]]; then
  theme_dir=~/.config/anarchy/themes/$theme
else
  theme_dir="$ANARCHY_PATH/themes/$theme"
fi

bg=$(awk -F'"' '/^background/{print $2}' "$theme_dir/colors.toml")
text=$(awk -F'"' '/^foreground/{print $2}' "$theme_dir/colors.toml")

exec anarchy-plymouth-set "$bg" "$text" "$theme_dir/unlock.png"
